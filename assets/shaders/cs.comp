#version 430 core
layout(local_size_x = 16,local_size_y = 16) in;

layout(rgba32f,binding = 0) uniform image2D outImage;

uniform uint width;
uniform uint height;
uniform uint tric;
uniform uint spherec;

uniform vec3 camPos;
uniform vec3 camForward;
uniform vec3 camRight;
uniform vec3 camUp;
uniform float camFov;

struct Mat{
    vec4 rgba;
};
struct Tri{
    vec4 v0;
    vec4 v1;
    vec4 v2;
    uint matId;
    uint pad0,pad1,pad2;
};
layout(std430,binding=1) readonly buffer TriBuf {
    Tri tris[];
};
struct Sphr {
    vec4 c_r;
    uint matId;
    uint pad0, pad1, pad2;
};
layout(std430,binding=2) readonly buffer SphrBuf {
    Sphr spheres[];
};
bool intersects(vec3 rayOrigin,vec3 rayVector,Tri tri, out float res){
    float epsilon=0.000001;
    vec3 v0=tri.v0.xyz;
    vec3 v1=tri.v1.xyz;
    vec3 v2=tri.v2.xyz;
    
    vec3 edge0=v1-v0;
    vec3 edge1=v2-v0;
    vec3 rayCrossE1=cross(rayVector,edge1);
    float det=dot(edge0,rayCrossE1);
    if(det>-epsilon&&det<epsilon){
        return false;
    }
    float invDet=1.0/det;
    vec3 s=rayOrigin-v0;
    float u=invDet*dot(s,rayCrossE1);
    if ( (u<0&&abs(u)>epsilon) || (u>1 && abs(u-1)>epsilon)){
        return false;
    }
    vec3 sCrossE0=cross(s,edge0);
    float v=invDet*dot(rayVector,sCrossE0);
    if ( (v<0&&abs(v)>epsilon) || (u+v>1 && abs(u+v-1)>epsilon)){
        return false;
    }
    res=invDet*dot(edge1,sCrossE0);
    if(res>epsilon){
        return true;
    }
    return false;
}
// bool intersectsAABB(vec3 rayOrigin,vec3 rayVector,vec3 a,vec3 b,float tMax){

// }
bool intersectsSphere(vec3 rayOrigin,vec3 rayVector,Sphr sphere,out float res){
    float epsilon=0.000001;
    vec3 cv=sphere.c_r.xyz;
    float r=sphere.c_r.w;
    vec3 L=cv-rayOrigin;
    float tca=dot(L,rayVector);
    if(tca<-epsilon){
        return false;
    }
    float sc=dot(L,L);
    float d2=sc-tca*tca;
    if(d2>r*r){
        return false;
    }
    float thc=sqrt(r*r-d2);
    float t0=tca-thc;
    float t1=tca+thc;
    float t;
    if (t0>epsilon){
        t=t0;
    }else if (t1>epsilon){
        t=t1;
    }else{
        t=-1.0;
    }
    if (t<-epsilon){
        return false;
    }
    res=t;
    return true;
}
struct RayHit{
    bool isValid;
    float t;
    uint matId;
    vec3 n;
};
RayHit trace(vec3 rayOrigin,vec3 rayVector){
    RayHit res;
    res.isValid=false;
    for (uint i=0;i<tric;++i){
        Tri tri=tris[i];
        float t;
        if(intersects(rayOrigin,rayVector,tri,t)){
            if (!res.isValid){
                res.isValid=true;
            }
            else if (res.t<t){
                continue;
            }
            res.t=t;
            res.matId=tri.matId;

            vec3 v0=tri.v0.xyz;
            vec3 v1=tri.v1.xyz;
            vec3 v2=tri.v2.xyz;
            res.n=normalize(cross(v1-v0,v2-v0));
        }
    }
    for (uint i=0;i<spherec;++i){
        Sphr sp=spheres[i];
        float t;
        if (intersectsSphere(rayOrigin,rayVector,sp,t)){
            if (!res.isValid){
                res.isValid=true;
            }
            else if (res.t<t){
                continue;
            }
            res.t=t;
            res.matId=sp.matId;

            vec3 cr=sp.c_r.xyz;
            vec3 p = rayOrigin+t*rayVector;
            res.n = normalize(p-cr);
        }
    }
    return res;

}

void main() {
    uvec2 gid = gl_GlobalInvocationID.xy;

    if (gid.x >= width||gid.y >= height){
        return;
    }
    float aspect=float(width)/float(height);
    vec3 rayOrigin=camPos;
    vec3 rayVector;
    vec3 color;
    vec3 lightSource=vec3(0.8,0.8,0.8);
    vec2 uv=vec2((gid.x+0.5)/float(width),(gid.y+0.5)/float(height));
    vec2 ndc=2.0*uv-1.0;
    ndc.x*=aspect;
    float fovTan=tan(0.5*camFov);

    rayVector=normalize(camForward+ndc.x*fovTan*camRight+ndc.y*fovTan*camUp);
    RayHit hit=trace(rayOrigin,rayVector);

    if (!hit.isValid){
        color=vec3(0.45,0.45,0.45);
    }else{
        vec3 L=normalize(lightSource);
        float d=dot(hit.n,L);
        if(d<0.0){
            d=0.0;
        }
        color=vec3(1.0,0.8,0.4)*d+vec3(0.05,0.05,0.05);
    }
    imageStore(outImage, ivec2(gid), vec4(color, 1.0));
}
